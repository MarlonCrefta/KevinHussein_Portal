# ⚠️ COPIE ESTE ARQUIVO PARA .env E CONFIGURE

# === SERVIDOR ===
NODE_ENV=production
PORT=3001

# === SEGURANÇA ===
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERE_UM_TOKEN_SEGURO_AQUI_64_BYTES_HEX
REFRESH_TOKEN_SECRET=GERE_OUTRO_TOKEN_SEGURO_AQUI_64_BYTES_HEX
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# === BANCO DE DADOS ===
DATABASE_PATH=./data/database.sqlite

# === SCHEDULER ===
ENABLE_SCHEDULER=true

# === WHATSAPP ===
WHATSAPP_SESSION_PATH=./auth_info_baileys

# === ADMIN INICIAL ===
ADMIN_USERNAME=kevin
ADMIN_PASSWORD=SUA_SENHA_FORTE_AQUI
ADMIN_NAME=Kevin Hussein

# === FRONTEND (Vite) ===
VITE_API_URL=http://localhost:3001/api
