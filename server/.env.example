# =====================================================
# KEVIN HUSSEIN TATTOO STUDIO - CONFIGURAÇÃO DO SERVIDOR
# =====================================================
# 
# COMO USAR:
#   1. Copie este arquivo: cp .env.example .env
#   2. Edite o .env com seus valores reais
#   3. Em PRODUÇÃO, JWT_SECRET, JWT_REFRESH_SECRET, ADMIN_PASSWORD
#      e FRONTEND_URL são OBRIGATÓRIOS (servidor não inicia sem eles)
#
# GERAR SECRETS SEGUROS:
#   openssl rand -base64 32
#

# ─── Servidor ───────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=localhost
# Em produção, use: HOST=0.0.0.0

# ─── Frontend URL (CORS) ───────────────────────
FRONTEND_URL=http://localhost:3000
# Em produção: https://seudominio.com

# ─── Banco de Dados ────────────────────────────
DATABASE_PATH=./data/database.sqlite

# ─── JWT (Autenticação) ────────────────────────
# OBRIGATÓRIO em produção — gere com: openssl rand -base64 32
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── WhatsApp ──────────────────────────────────
WHATSAPP_SESSION_PATH=./auth_info_baileys

# ─── Admin Padrão (criado no primeiro run) ─────
# OBRIGATÓRIO em produção — use senha forte
ADMIN_USERNAME=kevin
ADMIN_PASSWORD=
ADMIN_NAME=Kevin Hussein

# ─── Logs ──────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ─── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Scheduler ─────────────────────────────────
SCHEDULER_ENABLED=true
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=20
