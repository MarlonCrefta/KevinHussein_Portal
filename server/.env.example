# ====================================
# KEVIN HUSSEIN TATTOO STUDIO - SERVER
# ====================================
# Copie este arquivo para .env e configure

# Servidor
NODE_ENV=development
PORT=3001
HOST=localhost

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3000

# Banco de Dados
DATABASE_PATH=./data/database.sqlite

# JWT (Autenticação)
JWT_SECRET=sua-chave-secreta-aqui-mude-em-producao
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# WhatsApp
WHATSAPP_SESSION_PATH=./auth_info_baileys

# Admin Padrão (será criado no primeiro run)
ADMIN_USERNAME=kevin
ADMIN_PASSWORD=2026
ADMIN_NAME=Kevin Hussein

# Logs
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Scheduler
SCHEDULER_ENABLED=true
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=20
